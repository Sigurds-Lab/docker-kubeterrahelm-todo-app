# Example terraform.tfvars
# Customize these values for your deployment

aws_region          = "us-east-1"
cluster_name        = "wordpress-jamf-cluster"
kubernetes_version  = "1.27"
vpc_cidr            = "10.0.0.0/16"
instance_type       = "t3.medium"
desired_size        = 2
min_size            = 1
max_size            = 3
